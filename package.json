{
    "name": "sa-reviews",
    "version": "1.0.0",
    "description": "Fetching Google reviews from google using Javascript API and react",
    "scripts": {
        "build": "webpack --mode production",
        "start": "webpack --mode development --watch",
        "tailwind" : "npx tailwindcss -i ./src/index.css -o ./build/reviews.css --watch",
        "tailwindbuild" : "npx tailwindcss -i ./src/index.css -o ./build/reviews.css --minify"
    },
    "dependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-fancy-circular-carousel": "^1.0.8",
        "react-viewport-hooks": "^1.5.0"
    },
    "devDependencies": {
        "@babel/core": "^7.0.0",
        "@babel/preset-env": "^7.0.0",
        "@babel/preset-react": "^7.0.0",
        "@svgr/webpack": "^8.1.0",
        "babel-loader": "^8.0.0",
        "css-loader": "^7.1.2",
        "style-loader": "^4.0.0",
        "tailwindcss": "^3.4.15",
        "webpack": "^5.0.0",
        "webpack-cli": "^4.0.0"
    }
}
